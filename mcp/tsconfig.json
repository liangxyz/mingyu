{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/**/*",
    "../src/lib/**/*.ts",
    "../src/utils/**/*.ts",
    "../src/types/**/*.ts",
    "../src/config/**/*.ts",
    "../src/services/**/*.ts"
  ],
  "exclude": [
    "../src/**/*.tsx",
    "../src/hooks/**/*",
    "../src/pages/**/*",
    "../src/components/**/*",
    "../src/workers/**/*",
    "../src/main.tsx",
    "../src/App.tsx",
    "../src/registerServiceWorker.ts"
  ]
}
