{
  "name": "prompt-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "tsx --tsconfig tsconfig.app.json --test \"tests/**/*.test.ts\"",
    "lint": "eslint src --max-warnings 999",
    "lint:fix": "eslint src --fix --max-warnings 999",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"build/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"build/**/*.ts\"",
    "contest:evaluate": "node scripts/evaluate-fortune-contest-model.js",
    "mcp": "tsx --tsconfig mcp/tsconfig.json mcp/src/server.ts"
  },
  "dependencies": {
    "celestine": "^0.2.1",
    "iztro": "^2.5.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "tyme4ts": "^1.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.1.7",
    "zod": "^4.4.3"
  }
}
